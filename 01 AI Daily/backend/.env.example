# 复制此文件为 .env，填入你的 API Keys

# Anthropic Claude API（用于内容总结）
# 获取：https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# YouTube Data API v3（免费，每日 10000 配额）
# 获取：https://console.cloud.google.com/ → 创建项目 → 启用 YouTube Data API v3 → 创建 API Key
YOUTUBE_API_KEY=AIzaxxxxx

# X/Twitter API（可选，不填则使用 Nitter RSS 免费方案）
# 获取：https://developer.x.com/
X_BEARER_TOKEN=

# 转录开关（需要安装 faster-whisper，较重，默认关闭）
ENABLE_TRANSCRIPTION=false

# 每次采集的最大条数（每个平台）
MAX_ITEMS_PER_PLATFORM=10

# 采集多少小时内的内容（默认 24 小时）
HOURS_LOOKBACK=24
